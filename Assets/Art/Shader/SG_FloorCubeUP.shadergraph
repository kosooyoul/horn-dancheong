    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "OneHotMask",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float4 mask = saturate( 1.0 - abs( float4(0.0, 1.0, 2.0, 3.0)-index ) );\r\nOut =dot(RGBA, mask);"
}

